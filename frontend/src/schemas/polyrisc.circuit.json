    { "id": "alu", "type": "alu", "label": "ALU", "x": 460, "y": 280, "width": 80, "height": 70 },
    { "id": "data_mem", "type": "memory", "label": "Data Memory", "x": 620, "y": 120, "width": 100, "height": 80 },
    { "id": "mux_wb", "type": "multiplexer", "label": "WB MUX", "x": 620, "y": 280, "width": 60, "height": 80, "inputs": 3 },
